# ─── Backend API ───────────────────────────────────────────────────────
# URL of the Django backend (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── App identity (optional — shown in UI) ─────────────────────────────
NEXT_PUBLIC_APP_NAME=نظام توزيع الامتحانات

# ─── Production notes ──────────────────────────────────────────────────
# In production set NEXT_PUBLIC_API_URL to your deployed backend, e.g.:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
#
# Do NOT add NEXT_PUBLIC_ prefix to secrets — they are exposed to the browser.
# Server-only secrets belong in a separate .env (not .env.local) without that prefix.
